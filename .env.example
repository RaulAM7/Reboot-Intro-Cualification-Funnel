# Cal.com — link del calendario de orientación y namespace del embed
NEXT_PUBLIC_CAL_COM_LINK=raul-artiles-mendoza-n5juut/orientacion-reboot
NEXT_PUBLIC_CAL_COM_NAMESPACE=orientacion-reboot

# Google Analytics — dejar vacío si no tienes Measurement ID todavía
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Supabase — NUNCA expongas SUPABASE_SERVICE_ROLE_KEY con prefijo NEXT_PUBLIC_
# URL del proyecto: https://<project-ref>.supabase.co
SUPABASE_URL=
# Service role key (solo server-side, nunca al cliente)
SUPABASE_SERVICE_ROLE_KEY=
